# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://rca_user:rca_password@localhost:5432/rca_bot
DATABASE_URL_SYNC=postgresql+psycopg2://rca_user:rca_password@localhost:5432/rca_bot

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=incident-rca-bot

# Ticketing (stub)
TICKETING_WEBHOOK_URL=http://localhost:8080/api/tickets

# App
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000